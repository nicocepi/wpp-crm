# ============================================================================
# WhatsApp CRM — variables de entorno (ejemplo)
# Copia este archivo a .env (raiz) y/o a apps/crm/.env.local y apps/webhook/.env
# NUNCA commitees el .env real con credenciales.
# ============================================================================

# ---- Supabase --------------------------------------------------------------
# URL y anon/publishable key son publicas (van al browser en el CRM).
NEXT_PUBLIC_SUPABASE_URL=https://nimdkfnkvhjzwybalfex.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable__ItF3UPK3q-jKjd3mmeGeQ_lN8LgH_P
# SECRETA: solo backend (n8n / scripts). Dashboard -> Settings -> API -> service_role.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Meta WhatsApp ---------------------------------------------------------
# String inventado por vos; el mismo valor va en la config del webhook en Meta.
WHATSAPP_VERIFY_TOKEN=
# Settings -> Basic -> App Secret (para validar X-Hub-Signature-256).
WHATSAPP_APP_SECRET=
# Token temporal (24h) o System User token permanente.
WHATSAPP_API_TOKEN=

# ---- Claude API ------------------------------------------------------------
ANTHROPIC_API_KEY=

# ---- n8n -------------------------------------------------------------------
# Secret compartido entre el webhook service y n8n (header x-n8n-secret).
N8N_WEBHOOK_SECRET=
# Base URL de tu n8n (sin slash final). Ej: https://n8n.tudominio.com
N8N_BASE_URL=

# ---- App / Webhook ---------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Puerto del webhook service (apps/webhook).
WEBHOOK_PORT=8080

# ---- Alertas de handoff por email (CRM, server-only) -----------------------
# SMTP propio para enviar los avisos (nodemailer). Van en apps/crm/.env.local.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="CRM WhatsApp <avisos@tudominio.com>"
# Secreto compartido con n8n (header x-alert-secret). openssl rand -hex 24
HANDOFF_ALERT_SECRET=

# ---- Módulo de turnos (endpoints internos que consume n8n) -----------------
# Base URL del CRM que n8n usa para los endpoints internos de turnos
# (/api/internal/appointments/*). Local: http://host.docker.internal:3000
# En prod suele ser el mismo dominio del CRM. Sin slash final.
CRM_INTERNAL_URL=http://localhost:3000
# Secreto compartido con n8n (header x-appointment-secret). openssl rand -hex 24
APPOINTMENTS_INTERNAL_SECRET=

# ---- Google Calendar (conexión OAuth por empresa) --------------------------
# Credenciales de un OAuth Client ID tipo "Web application" en Google Cloud
# Console (con la Calendar API habilitada). Ver docs/appointments.md para el
# paso a paso. El redirect URI DEBE coincidir exacto con el configurado ahí.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback
# Clave AES-256 para cifrar access_token/refresh_token de Google en la DB
# (cifrado en la app, no en Postgres). openssl rand -hex 32
GCAL_TOKEN_ENCRYPTION_KEY=
