# ============================================================================
# WhatsApp CRM — variables de entorno (ejemplo)
# Copia este archivo a .env (raiz) y/o a apps/crm/.env.local y apps/webhook/.env
# NUNCA commitees el .env real con credenciales.
# ============================================================================

# ---- Supabase --------------------------------------------------------------
# URL y anon/publishable key son publicas (van al browser en el CRM).
NEXT_PUBLIC_SUPABASE_URL=https://nimdkfnkvhjzwybalfex.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable__ItF3UPK3q-jKjd3mmeGeQ_lN8LgH_P
# SECRETA: solo backend (n8n / scripts). Dashboard -> Settings -> API -> service_role.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Meta WhatsApp ---------------------------------------------------------
# String inventado por vos; el mismo valor va en la config del webhook en Meta.
WHATSAPP_VERIFY_TOKEN=
# Settings -> Basic -> App Secret (para validar X-Hub-Signature-256).
WHATSAPP_APP_SECRET=
# Token temporal (24h) o System User token permanente.
WHATSAPP_API_TOKEN=

# ---- Claude API ------------------------------------------------------------
ANTHROPIC_API_KEY=

# ---- n8n -------------------------------------------------------------------
# Secret compartido entre el webhook service y n8n (header x-n8n-secret).
N8N_WEBHOOK_SECRET=
# Base URL de tu n8n (sin slash final). Ej: https://n8n.tudominio.com
N8N_BASE_URL=

# ---- App / Webhook ---------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Puerto del webhook service (apps/webhook).
WEBHOOK_PORT=8080
