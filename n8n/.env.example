# Variables para docker-compose de n8n (copia a n8n/.env).
# n8n/.env NO se commitea.

# Postgres de n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=cambia-esto
POSTGRES_DB=n8n

# n8n core
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_BASE_URL=http://localhost:5678
TZ=America/Argentina/Buenos_Aires
# Genera uno con: openssl rand -hex 24
N8N_ENCRYPTION_KEY=
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=cambia-esto

# Variables que consume el workflow (via {{ $env.X }})
SUPABASE_URL=https://nimdkfnkvhjzwybalfex.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=
WHATSAPP_API_TOKEN=
N8N_WEBHOOK_SECRET=
